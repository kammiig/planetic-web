###########################################################################
# Planetic Web — Environment Configuration
#
# Copy to .env and fill in real values. NEVER commit a real .env file.
# No secret key may be exposed to the frontend or committed to version
# control. In production set APP_DEBUG=false.
###########################################################################

APP_NAME="Planetic Web"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://planeticweb.com
APP_TIMEZONE=Europe/London

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

#--------------------------------------------------------------------------
# Database (MySQL on cPanel in production)
#--------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=YOUR_CPANEL_DATABASE_NAME
DB_USERNAME=YOUR_CPANEL_DATABASE_USER
DB_PASSWORD=YOUR_DATABASE_PASSWORD

#--------------------------------------------------------------------------
# Sessions / Cache / Queue — all database-backed for cPanel
#--------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

#--------------------------------------------------------------------------
# Mail — Namecheap cPanel Email SMTP (Jellyfish filtering)
#--------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mail.planeticweb.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@planeticweb.com
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@planeticweb.com"
MAIL_FROM_NAME="Planetic Web"
# Alternative TLS setup: MAIL_PORT=587 and MAIL_ENCRYPTION=tls

#--------------------------------------------------------------------------
# Stripe
#--------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp

#--------------------------------------------------------------------------
# Billing / Renewals
#--------------------------------------------------------------------------
BILLING_GRACE_PERIOD_DAYS=7
RENEWAL_REMINDER_DAYS_BEFORE=30,14,7,3,1
WEBSITE_PACKAGE_PRICE=200.00

#--------------------------------------------------------------------------
# Domain Registrar — NameSilo (primary), Namecheap (backup)
#--------------------------------------------------------------------------
DOMAIN_REGISTRAR=namesilo

NAMESILO_API_KEY=
NAMESILO_API_ENDPOINT=https://www.namesilo.com/api
NAMESILO_SANDBOX=false

NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_API_ENDPOINT=https://api.namecheap.com/xml.response
NAMECHEAP_SANDBOX=false

#--------------------------------------------------------------------------
# Namecheap WHM / cPanel Hosting
#--------------------------------------------------------------------------
WHM_HOST=
WHM_PORT=2087
WHM_USERNAME=
WHM_API_TOKEN=
WHM_VERIFY_SSL=true
WHM_DEFAULT_PACKAGE=kwashqap_starter
WHM_SERVER_IP=
WHM_SERVER_HOSTNAME=
WHM_CPANEL_LOGIN_URL=
WHM_USERNAME_PREFIX=pw

#--------------------------------------------------------------------------
# Cloudflare DNS
#--------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DEFAULT_SSL_MODE=full
CLOUDFLARE_ALWAYS_USE_HTTPS=true
CLOUDFLARE_PROXIED_WEBSITE_RECORDS=true

DEFAULT_DNS_TTL=1
DEFAULT_MAIL_SERVER_HOSTNAME=mail
DEFAULT_DMARC_POLICY=none

#--------------------------------------------------------------------------
# Provisioning
#--------------------------------------------------------------------------
# PROVISIONING_SYNC=true  → provision inline the moment a verified Stripe
#   webhook confirms payment (no queue worker required — recommended on cPanel).
#   Set to false only if you run a dedicated queue worker.
# PROVISIONING_DRY_RUN=true → simulate registrar/WHM/Cloudflare so the full
#   checkout → dashboard flow can be tested with Stripe test keys only. Never
#   enable in production.
PROVISIONING_SYNC=true
PROVISIONING_DRY_RUN=false

#--------------------------------------------------------------------------
# Operational Email Addresses
#--------------------------------------------------------------------------
ADMIN_EMAIL=admin@planeticweb.com
SUPPORT_EMAIL=support@planeticweb.com
BILLING_EMAIL=billing@planeticweb.com

#--------------------------------------------------------------------------
# Frontend (Vite) — only the PUBLIC Stripe key is ever exposed
#--------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
